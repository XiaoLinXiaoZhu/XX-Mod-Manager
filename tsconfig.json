{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,

    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node","bun"],
    "paths": {
      "@xxmm/types": ["./packages/types/src/index.ts"],
      "@xxmm/types/*": ["./packages/types/src/*"],
      "@xxmm/ipc": ["./packages/ipc/src/index.ts"],
      "@xxmm/ipc/*": ["./packages/ipc/src/*"],
      "@xxmm/core": ["./packages/core/src/index.ts"],
      "@xxmm/core/*": ["./packages/core/src/*"],
      "@xxmm/helper": ["./packages/helper/src/index.ts"],
      "@xxmm/helper/*": ["./packages/helper/src/*"],
      "@xxmm-apps/electron": ["./apps/electron/src"],
      "@xxmm-apps/electron/*": ["./apps/electron/src/*"],
      "@xxmm-apps/vault": ["./apps/desktop/vault/src"],
      "@xxmm-apps/vault/*": ["./apps/desktop/vault/src/*"],
      "@xxmm-apps/first-load": ["./apps/desktop/first-load/src"],
      "@xxmm-apps/first-load/*": ["./apps/desktop/first-load/src/*"],
      "@xxmm-apps/switch-config": ["./apps/desktop/switch-config/src"],
      "@xxmm-apps/switch-config/*": ["./apps/desktop/switch-config/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "apps/**/*.d.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
