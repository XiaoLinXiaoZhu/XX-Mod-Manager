{
  "name": "xx-mod-manager",
  "private": true,
  "description": "xx-mod-manager",
  "main": "./apps/electron/dist/main.mjs",
  "author": "XLXZ",
  "license": "GPL-3.0-only",
  "version": "1.4.0",
  "type": "commonjs",
  "workspaces": [
    "packages/*",
    "apps/electron",
    "apps/desktop/vault",
    "apps/desktop/first-load",
    "apps/desktop/switch-config"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "check": "bunx biome check --write .",
    "dev:frontend": "bun run --bun vite",
    "dev:electron": "bun run build:electron-main && electron . --dev --devTools",
    "dev:electron:customConfig": "bun run build:electron-main && electron . --dev --devTools --customConfig D:\\GameResource\\ZZMI\\customConfig",
    "dev:electron:firstpage": "bun run build:electron-main && electron . --dev --devTools --firstpage",
    "dev:electron:switchConfig": "bun run build:electron-main && electron . --dev --devTools --switchConfig",
    "dev": "bun run --parallel dev:frontend dev:electron",
    "dev:customConfig": "bun run --parallel dev:frontend dev:electron:customConfig",
    "dev:firstpage": "bun run --parallel dev:frontend dev:electron:firstpage",
    "dev:switchConfig": "bun run --parallel dev:frontend dev:electron:switchConfig",
    "build:frontend": "vite build",
    "build:electron": "electron-builder --win --linux",
    "build": "bun run --sequential build:frontend build:electron",
    "preview": "vite preview",
    "start": "electron .",
    "publish": "electron-builder --publish always",
    "build:electron-main": "bun build apps/electron/src/main.ts --outfile=apps/electron/dist/main.mjs --target=node --format=esm --external=electron --external=hmc-win32"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "hmc-win32": "^1.4.92",
    "sober": "^1.1.10",
    "three": "^0.185.0",
    "vite": "^8.1.0",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "@types/bun": "^1.3.14"
  }
}
